<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.project.mapper.SearchMapper">

<!--  	 <select id="searchList" resultType="com.project.dto.ProductDTO">
