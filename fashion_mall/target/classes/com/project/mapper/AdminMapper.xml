	 <!-- 리스트 불러오는 어쩌고 -->
	 <select id="selectList" resultType="com.project.dto.ProductDTO">
	 	select p_code,p_name,p_sale,reg_date from product order by reg_date desc
	 </select>
	 
	 <!-- 리스트 read 페이지 -->
	 <select id="selectProduct" resultType="com.project.dto.ProductDTO">
	 	select p_code from product
	 </select>
	
	
</mapper>