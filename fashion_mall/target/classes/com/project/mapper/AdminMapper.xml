<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.project.mapper.AdminMapper">

	
	<!-- product 입력 -->
	<insert id="insert" parameterType="com.project.dto.ProductDTO">
		<!-- selectKey : 주로 pk 값을 미리 실행 한 후 특정 이름으로 보관
		      - keyProperty : 결과값이 세팅될 대상 프로퍼티
		      - order : 키를 먼저 조회
		 -->
		<!-- p_code 발행 -->
	<!-- 	<selectKey keyProperty="p_code" order="BEFORE" resultType="int">
			select seq_board.nextval from dual
		</selectKey>	 -->
		<selectKey keyProperty="p_code" order="BEFORE" resultType="int">
			select product_seq.nextval from dual
		</selectKey> 
			 insert into Product(p_code,p_name,p_price,p_type,p_content)
		values(#{p_code},#{p_name},#{p_price},#{p_type},#{p_content})
		</insert>
		
	

    <!-- 상품 옵션 등록 -->
    <insert id="OptInsert">
    
        <selectKey keyProperty="p_code" order="BEFORE" resultType="int">
			select max(p_code) from product
		</selectKey>
        insert into ProductOpt(p_code, po_size, po_color, p_amount) values(#{p_code}, #{po_size}, #{po_color}, #{p_amount})
    </insert>
		
